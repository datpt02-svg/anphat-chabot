POSTGRES_DB=anphat_commerce
POSTGRES_USER=anphat
POSTGRES_PASSWORD=anphat_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://anphat:anphat_dev_password@localhost:5432/anphat_commerce

# Read-only role for the agent (created in migration 005)
DATABASE_RO_URL=postgresql://agent_readonly:CHANGE_ME@localhost:5432/anphat_commerce

MEILI_PORT=7700
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=anphat_meili_dev_master_key
MEILI_PRODUCTS_INDEX=products
MEILI_TIMEOUT_SECONDS=30
MEILI_SYNC_BATCH_SIZE=5000
SEARCH_FALLBACK_ENABLED=true
SEARCH_MAX_LIMIT=100

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- M5: Secrets bootstrap ---
# Set to "aws" to load from AWS Secrets Manager, "env" to use this .env file.
SECRETS_SOURCE=env
AWS_SECRETS_PREFIX=anphat/agent/
AWS_REGION=ap-southeast-1

# --- M5: Anthropic / LLM ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-8

# --- M5: Provider abstraction (vast-painting-sparkle plan §1) ---
# anthropic | openai | ollama | vllm
LLM_PROVIDER=anthropic
# OPENAI_BASE_URL empty = OpenAI official; auto-fill `http://localhost:11434/v1` (Ollama) / `http://localhost:8000/v1` (vLLM) via provider
OPENAI_BASE_URL=
# OpenAI-compatible key; default "ollama" cho local dev (không check auth)
OPENAI_API_KEY=ollama
# Generic 3-tier (override mỗi khi đổi provider)
LLM_DEFAULT_FAST_MODEL=
LLM_DEFAULT_BALANCED_MODEL=
LLM_DEFAULT_SMART_MODEL=

# --- M5: Step display (vast-painting-sparkle plan §1) ---
SHOW_AGENT_STEPS=true

# --- M5: Token caps per tier (vast-painting-sparkle plan §3.2) ---
AGENT_MAX_OUTPUT_TOKENS_FAST=2000
AGENT_MAX_OUTPUT_TOKENS_SMART=16000

# --- M5: Debug ---
# Expose raw LLM I/O in step metadata (PII risk, admin only)
DEBUG_EXPOSE_LLM_IO=false

# --- M5: Langfuse (leave empty to use local JSON logging) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_SAMPLING_RATE=1.0
LANGFUSE_ENVIRONMENT=dev

# --- M5: JWT auth ---
JWT_ALGORITHM=HS256
JWT_SECRET=change_me_in_prod
JWT_JWKS_URL=

# --- M5: HMAC for user_id hashing ---
HMAC_SALT=change_me_in_prod
HMAC_SALT_VERSION=v1

# --- M5: Daily budget counter ---
AGENT_DAILY_BUDGET_TOKENS=2000000
AGENT_BUDGET_ALERT_PCT=80
AGENT_BUDGET_KILL_PCT=100

# --- M5: Agent runtime caps ---
AGENT_MAX_INPUT_TOKENS=10000
AGENT_MAX_OUTPUT_TOKENS=2000
AGENT_MAX_TURNS_PER_SESSION=20
AGENT_NODE_TIMEOUT_S=30
AGENT_RECURSION_LIMIT=5
AGENT_HEARTBEAT_S=5
